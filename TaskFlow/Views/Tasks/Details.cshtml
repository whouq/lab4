@model TaskFlow.Models.Task

@{
    ViewData["Title"] = "Детали задачи";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Список задач</a></li>
        <li class="breadcrumb-item active" aria-current="page">Детали задачи</li>
    </ol>
</nav>


<h1 class="mb-4">👁️ Детали задачи</h1>


<div class="card">
    <div class="card-header bg-primary text-white">
        <h3 class="card-title mb-0">@Model.Title</h3>
    </div>
    <div class="card-body">
      
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="mb-4">
                <h5 class="text-muted">Описание:</h5>
                <p class="lead">@Model.Description</p>
            </div>
        }

        <div class="mb-3">
            <strong>Приоритет:</strong>
            @switch (Model.Priority)
            {
                case TaskFlow.Models.TaskPriority.High:
                    <span class="badge bg-danger ms-2">🔥 Высокий</span>
                    break;
                case TaskFlow.Models.TaskPriority.Medium:
                    <span class="badge bg-warning text-dark ms-2">🟡 Средний</span>
                    break;
                case TaskFlow.Models.TaskPriority.Low:
                    <span class="badge bg-success ms-2">🟢 Низкий</span>
                    break;
            }
        </div>

        <div class="mb-3">
            <strong>Статус:</strong>
            @switch (Model.Status)
            {
                case TaskFlow.Models.TaskStatus.New:
                    <span class="badge bg-info ms-2">🆕 Новая</span>
                    break;
                case TaskFlow.Models.TaskStatus.InProgress:
                    <span class="badge bg-primary ms-2">🔄 В работе</span>
                    break;
                case TaskFlow.Models.TaskStatus.Completed:
                    <span class="badge bg-success ms-2">✅ Завершена</span>
                    break;
                case TaskFlow.Models.TaskStatus.Cancelled:
                    <span class="badge bg-secondary ms-2">❌ Отменена</span>
                    break;
            }
        </div>

        <div class="mb-3">
            <strong>Прогресс:</strong>
            <div class="progress mt-2" style="height: 25px;">
                <div class="progress-bar @(GetProgressClass(Model.Progress))"
                     role="progressbar"
                     style="width: @Model.Progress%"
                     aria-valuenow="@Model.Progress"
                     aria-valuemin="0"
                     aria-valuemax="100">
                    @Model.Progress%
                </div>
            </div>
        </div>

        <div class="mb-3">
            <strong>Дедлайн:</strong>
            @if (Model.Deadline.HasValue)
            {
                <span class="@(Model.Deadline.Value.Date <= DateTime.Now.AddDays(3).Date && Model.Deadline.Value.Date >= DateTime.Now.Date && Model.Status != TaskFlow.Models.TaskStatus.Completed ? "text-danger fw-bold" : "")">
                    @Model.Deadline.Value.ToString("dd.MM.yyyy HH:mm")
                </span>
            }
            else
            {
                <span class="text-muted">Не указан</span>
            }
        </div>

        @if (Model.CompletedAt.HasValue)
        {
            <div class="mb-3">
                <strong>Завершена:</strong>
                <span>@Model.CompletedAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
            </div>
        }

        <div class="mb-3">
            <strong>Создатель:</strong>
            <span>@Model.Creator</span>
        </div>

        <div class="mb-3">
            <strong>Исполнитель:</strong>
            <span>@(string.IsNullOrEmpty(Model.Assignee) ? "Не назначен" : Model.Assignee)</span>
        </div>

        <div class="mb-3">
            <strong>Создана:</strong>
            <span>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
        </div>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Редактировать
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Назад к списку
        </a>
    </div>
</div>

@functions {
    string GetProgressClass(int progress)
    {
        if (progress < 30) return "bg-danger";
        if (progress < 70) return "bg-warning";
        return "bg-success";
    }
}