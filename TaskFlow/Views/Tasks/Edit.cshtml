@model TaskFlow.Models.Task

@{
    ViewData["Title"] = "Редактировать задачу";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Список задач</a></li>
        <li class="breadcrumb-item active" aria-current="page">Редактировать задачу</li>
    </ol>
</nav>
<h1 class="mb-4">✏️ Редактировать задачу</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Priority" class="form-label"></label>
                <select asp-for="Priority" class="form-select">
                    <option value="1">🟢 Низкий</option>
                    <option value="2">🟡 Средний</option>
                    <option value="3">🔥 Высокий</option>
                </select>
                <span asp-validation-for="Priority" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select">
                    <option value="1">🆕 Новая</option>
                    <option value="2">🔄 В работе</option>
                    <option value="3">✅ Завершена</option>
                    <option value="4">❌ Отменена</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Deadline" class="form-label"></label>
                <input asp-for="Deadline" class="form-control" type="datetime-local" />
                <span asp-validation-for="Deadline" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CompletedAt" class="form-label">Дата завершения</label>
                <input asp-for="CompletedAt" class="form-control" type="datetime-local" readonly />
                <span asp-validation-for="CompletedAt" class="text-danger"></span>
                <small class="text-muted">Устанавливается автоматически при завершении задачи</small>
            </div>

            <div class="mb-3">
                <label asp-for="Progress" class="form-label"></label>
                <input asp-for="Progress" class="form-control" type="number" min="0" max="100" />
                <span asp-validation-for="Progress" class="text-danger"></span>
                <div class="progress mt-2" style="height: 20px;">
                    <div class="progress-bar" role="progressbar" style="width: @Model.Progress%" aria-valuenow="@Model.Progress" aria-valuemin="0" aria-valuemax="100">
                        @Model.Progress%
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Creator" class="form-label"></label>
                <input asp-for="Creator" class="form-control" readonly />
                <span asp-validation-for="Creator" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Assignee" class="form-label"></label>
                <input asp-for="Assignee" class="form-control" />
                <span asp-validation-for="Assignee" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Сохранить
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-circle"></i> Отмена
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}